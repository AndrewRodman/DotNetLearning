<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:TaskApp.Models;assembly=TaskApp.Core"
             x:Class="TaskApp.Pages.TasksPage"
             Title="My Tasks">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">
        <HorizontalStackLayout Grid.Row="0" Spacing="8">
            <Button Text="Refresh" Clicked="OnRefreshClicked" />
            <Button Text="Logout"
                    Style="{StaticResource SecondaryActionButton}"
                    Clicked="OnLogoutClicked" />
            <Picker Title="Filter" x:Name="FilterPicker" SelectedIndexChanged="FilterPickerSelectedIndexChanged" SelectedIndex="0">
                <Picker.Items>
                    <x:String>All</x:String>
                    <x:String>Open</x:String>
                    <x:String>Complete</x:String>
                </Picker.Items>
            </Picker>
        </HorizontalStackLayout>

        <CollectionView x:Name="TasksCollection"
                        Grid.Row="1"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:TaskItem">
                    <Border Style="{StaticResource TaskCard}">
                        <VerticalStackLayout Spacing="6">
                            <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="8">
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsComplete, Mode=OneWay}"
                                          CheckedChanged="OnTaskCompleteChanged"
                                          VerticalOptions="Center" />
                                <Label Grid.Column="1"
                                       Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       LineBreakMode="TailTruncation" />
                                <Button Grid.Column="2"
                                        Text="Edit"
                                        Style="{StaticResource TaskEditButton}"
                                        Clicked="OnEditTaskClicked" />
                                <Button Grid.Column="3"
                                        Text="Delete"
                                        Style="{StaticResource TaskDeleteButton}"
                                        Clicked="OnDeleteTaskClicked" />
                            </Grid>
                            <Label Text="{Binding Description}"
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                   FontSize="12" />
                            <Label Text="{Binding DueDate, StringFormat='{0:MM-dd-yyyy}'} "
                                   TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray300}}"
                                   FontSize="12" 
                                   IsVisible="True">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label"
                                                 Binding="{Binding DueDate}"
                                                 Value="{x:Null}">
                                        <Setter Property="IsVisible" Value="False" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <VerticalStackLayout Grid.Row="2" Spacing="8">
            <Entry x:Name="NewTitleEntry" Placeholder="New task title" />
            <Entry x:Name="NewDescriptionEntry" Placeholder="Description (optional)" />
            <HorizontalStackLayout>
                <CheckBox x:Name="DueDateCB" IsChecked="False" CheckedChanged="DueDateCB_CheckedChanged"></CheckBox>
                <Label VerticalTextAlignment="Center" Text="Due Date?"></Label>
                <DatePicker x:Name="DueDatePicker" IsVisible="False" Margin="10"></DatePicker>
            </HorizontalStackLayout>
            <Button Text="Add Task" Clicked="OnAddTaskClicked" />
            <Label x:Name="StatusLabel" TextColor="Red" IsVisible="False" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>