@TaskApi_HostAddress = https://taskapi-andrew.azurewebsites.net
//@TaskApi_HostAddress = http://localhost:5046


###############################################
# Health check (no auth required)
# Success = 200 OK with body "Healthy"
###############################################

GET {{TaskApi_HostAddress}}/health

###

###############################################
# STEP 1: Register — RUN THIS FIRST (before Login)
# Success = JSON with "token". If 409, user exists: try Login.
# Password must be at least 6 characters.
###############################################

POST {{TaskApi_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "username": "demo",
  "password": "Password123"
}

###

###############################################
# STEP 2: Login — RUN THIS before any task request
# After it succeeds, run step 3 below
###############################################

# @name login
POST {{TaskApi_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "username": "demo",
  "password": "Password123"
}

###

###############################################
# STEP 3: Tasks (uses token from Login above)
###############################################

GET {{TaskApi_HostAddress}}/api/tasks
Authorization: Bearer {{login.response.body.$.token}}
Accept: application/json

###

GET {{TaskApi_HostAddress}}/api/tasks?isComplete=true
Authorization: Bearer {{login.response.body.$.token}}
Accept: application/json

###

GET {{TaskApi_HostAddress}}/api/tasks?isComplete=false
Authorization: Bearer {{login.response.body.$.token}}
Accept: application/json

###

GET {{TaskApi_HostAddress}}/api/tasks/1
Authorization: Bearer {{login.response.body.$.token}}
Accept: application/json

###

POST {{TaskApi_HostAddress}}/api/tasks
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "title": "AZURE2 Learn JWT auth",
  "description": "Stage 3 auth complete"
}

###

PUT {{TaskApi_HostAddress}}/api/tasks/1
Authorization: Bearer {{login.response.body.$.token}}
Content-Type: application/json

{
  "title": "Learn JWT auth",
  "description": "Stage 3 auth complete",
  "isComplete": true
}

###

DELETE {{TaskApi_HostAddress}}/api/tasks/1
Authorization: Bearer {{login.response.body.$.token}}

###