@page
@model TaskWeb.Pages.CreateModel
@{
    ViewData["Title"] = "New Task";
}

<div class="form-card mx-auto">
    <div class="page-header">
        <h1>New Task</h1>
        <p>Add a task to your list</p>
    </div>

    <div class="card task-card">
        <div class="card-body p-4">
            @if (!string.IsNullOrEmpty(Model.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">@Model.ErrorMessage</div>
            }

            <form method="post">
                <div class="mb-3">
                    <label asp-for="Title" class="form-label">Title</label>
                    <input asp-for="Title" class="form-control" placeholder="What needs to be done?" />
                </div>

                <div class="mb-3">
                    <label asp-for="Description" class="form-label">Description</label>
                    <textarea asp-for="Description" class="form-control" rows="3" placeholder="Optional details"></textarea>
                </div>

                <div class="mb-3 form-check">
                    <input asp-for="HasDueDate" type="checkbox" class="form-check-input js-due-date-toggle" />
                    <label asp-for="HasDueDate" class="form-check-label">Due date</label>
                </div>

                <div class="mb-4 due-date-field">
                    <label asp-for="DueDate" class="form-label">Due date</label>
                    <input asp-for="DueDate" type="date" class="form-control" />
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">Create Task</button>
                    <a asp-page="/Tasks" class="btn btn-outline-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>